              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Ford\",\n  \"model\": \"Focus\",\n  \"category\": \"Sedan\",\n  \"price\": 20000,\n  \"quantity\": -3\n}"
            }
          }
        },

        {
          "name": "[F5-6] Create vehicle – missing required fields (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Toyota\"\n}"
            }
          }
        },

        {
          "name": "[F5-7] Create vehicle – no auth token (401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"category\": \"Sedan\",\n  \"price\": 25000,\n  \"quantity\": 10\n}"
            }
          }
        },

        {
          "name": "[F6-1] List all vehicles (200)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F6-2] List vehicles – no auth (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles"
          }
        },

        {
          "name": "[F8-1] Update vehicle – price only (partial, 200)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/vehicles/{{vehicleId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 28000\n}"
            }
          }
        },

        {
          "name": "[F8-2] Update vehicle – full update (200)",
          "request": {
