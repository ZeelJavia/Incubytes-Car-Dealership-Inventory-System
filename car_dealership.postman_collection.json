{
  "info": {
    "name": "Car Dealership Inventory System",
    "description": "Complete API test collection covering all endpoints and edge cases",
    "_postman_id": "car-dealership-api-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:3001" },
    { "key": "userToken",  "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "vehicleId",  "value": "" }
  ],
  "item": [

    {
      "name": "── AUTH ──",
      "item": [

        {
          "name": "[F1-1] Register – valid (201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Smith\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "pm.test('has token', () => pm.expect(pm.response.json().token).to.be.a('string'));",
                "pm.test('no passwordHash', () => pm.expect(pm.response.json().user).to.not.have.property('passwordHash'));",
                "pm.collectionVariables.set('userToken', pm.response.json().token);"
              ]
            }
          }]
        },

        {
          "name": "[F1-2] Register – duplicate email (409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Again\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "[F1-3] Register – missing name (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "[F1-4] Register – invalid email (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"not-an-email\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "[F1-5] Register – short password <8 chars (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"short\"\n}"
            }
          }
        },

        {
          "name": "[F1-6] Register – empty body (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{}" }
          }
        },

        {
          "name": "[F2-1] Login – valid credentials (200 + JWT)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('status 200', () => pm.response.to.have.status(200));",
                "pm.collectionVariables.set('userToken', pm.response.json().token);"
              ]
            }
          }]
        },

        {
          "name": "[F2-2] Login – wrong password (401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"WrongPassword\"\n}"
            }
          }
        },

        {
          "name": "[F2-3] Login – unknown email (401, same msg as wrong pwd)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "[F2-4] Login – missing password field (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\"\n}"
            }
          }
        },

        {
          "name": "[F2-5] Login – missing email field (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"Password123\"\n}"
            }
          }
        },

        {
          "name": "[ADMIN-SETUP] Register admin user (201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.collectionVariables.set('adminToken', pm.response.json().token);"
              ]
            }
          }]
        }

      ]
    },

    {
      "name": "── AUTH MIDDLEWARE ──",
      "item": [

        {
          "name": "[F3-1] No token → 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles"
          }
        },

        {
          "name": "[F3-2] Malformed token → 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [{ "key": "Authorization", "value": "Bearer this.is.not.valid" }]
          }
        },

        {
          "name": "[F3-3] Expired token → 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJ0ZXN0Iiwicm9sZSI6IlVTRVIiLCJpYXQiOjE2MDAwMDAwMDAsImV4cCI6MTYwMDAwMDAwMX0.fake_expired" }
            ]
          }
        },

        {
          "name": "[F3-4] Token without Bearer prefix → 401",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [{ "key": "Authorization", "value": "{{userToken}}" }]
          }
        }

      ]
    },

    {
      "name": "── VEHICLES (CRUD) ──",
      "item": [

        {
          "name": "[F5-1] Create vehicle – valid (201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Toyota\",\n  \"model\": \"Camry\",\n  \"category\": \"Sedan\",\n  \"price\": 25000,\n  \"quantity\": 10\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('status 201', () => pm.response.to.have.status(201));",
                "pm.test('has id', () => pm.expect(pm.response.json().id).to.be.a('string'));",
                "pm.collectionVariables.set('vehicleId', pm.response.json().id);"
              ]
            }
          }]
        },

        {
          "name": "[F5-2] Create vehicle – quantity=0 (valid, 201)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Honda\",\n  \"model\": \"Civic\",\n  \"category\": \"Sedan\",\n  \"price\": 22000,\n  \"quantity\": 0\n}"
            }
          }
        },

        {
          "name": "[F5-3] Create vehicle – negative price (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Ford\",\n  \"model\": \"Focus\",\n  \"category\": \"Sedan\",\n  \"price\": -5000,\n  \"quantity\": 10\n}"
            }
          }
        },

        {
          "name": "[F5-4] Create vehicle – price = 0 (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/vehicles",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"make\": \"Ford\",\n  \"model\": \"Focus\",\n  \"category\": \"Sedan\",\n  \"price\": 0,\n  \"quantity\": 10\n}"
            }
          }
        },

        {
          "name": "[F5-5] Create vehicle – negative quantity (400)",
