          }
        }

      ]
    },

    {
      "name": "── SEARCH / FILTER ──",
      "item": [

        {
          "name": "[F7-1] Search by make (case-insensitive)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?make=toyota",
              "query": [{ "key": "make", "value": "toyota" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-2] Search by category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?category=Sedan",
              "query": [{ "key": "category", "value": "Sedan" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-3] Search by price range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?minPrice=20000&maxPrice=30000",
              "query": [
                { "key": "minPrice", "value": "20000" },
                { "key": "maxPrice", "value": "30000" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-4] Search multi-filter: make + category + minPrice",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?make=Toyota&category=Sedan&minPrice=24000",
              "query": [
                { "key": "make", "value": "Toyota" },
                { "key": "category", "value": "Sedan" },
                { "key": "minPrice", "value": "24000" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-5] Search – no matches → empty array (200, not 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?make=Lamborghini",
              "query": [{ "key": "make", "value": "Lamborghini" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-6] Search – non-numeric minPrice (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?minPrice=notanumber",
              "query": [{ "key": "minPrice", "value": "notanumber" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-7] Search – non-numeric maxPrice (400)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/vehicles/search?maxPrice=abc",
              "query": [{ "key": "maxPrice", "value": "abc" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }]
          }
        },

        {
          "name": "[F7-8] Search – no auth (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/vehicles/search?make=Toyota"
          }
        }

